# Google OAuth Client Credentials
GOOGLE_CLIENT_ID=your_gcp_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_gcp_client_secret

# Google OAuth Redirect URI (routed through port 80 proxy)
# Locally: http://localhost/auth/callback
# VM: http://your-vm-ip/auth/callback
GOOGLE_REDIRECT_URI=http://localhost/auth/callback

# Frontend URL entry point (port 80)
# Locally: http://localhost
# VM: http://your-vm-ip
FRONTEND_URL=http://localhost

# AI Service Keys (Gemini is free and recommended, OpenAI fallback is supported)
GEMINI_API_KEY=your_gemini_api_key_from_ai_studio
OPENAI_API_KEY=
